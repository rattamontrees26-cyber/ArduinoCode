void handleSetup() {
    String ssid = server.arg("ssid");
    String wifi_password = server.arg("wifi_password");
    String mqtt_topic = server.arg("mqtt_topic");

    Serial.println("WiFi SSID: " + ssid);
    Serial.println("WiFi Password: " + wifi_password);
    Serial.println("MQTT Topic: " + mqtt_topic);

    WiFi.begin(ssid.c_str(), wifi_password.c_str());

    int timeout = 0;
    while (WiFi.status() != WL_CONNECTED && timeout < 30) {
        delay(1000);
        timeout++;
    }

    if (WiFi.status() == WL_CONNECTED) {
        saveSettingsToEEPROM(ssid, wifi_password, mqtt_topic);

        WiFi.softAPdisconnect(true);
        WiFi.mode(WIFI_STA);

        mqtt_topics.clear();
        mqtt_topics.push_back(mqtt_topic);
        client.setServer(mqtt_server, mqtt_port);
        client.setCallback(callback);
        espClient.setInsecure();
        reconnect(); 

        IPAddress ip = WiFi.localIP();
        String ipStr = ip.toString();

        String successHtml = "<h2>WiFi and MQTT Settings Saved</h2>";
        successHtml += "<p>Connected to WiFi: " + ssid + "</p>";
        successHtml += "<p>Device IP: " + ipStr + "</p>";
        successHtml += "<p><a href='http://" + ipStr + "'>Go to device page</a></p>";

        server.send(200, "text/html", successHtml);
    } else {
        server.send(200, "text/html", "<h2>WiFi Connection Failed</h2>");
    }
}

void reconnect() {
    if (!client.connected()) {
        Serial.print("Attempting MQTT connection...");
        if (client.connect("ESP32Client", mqtt_user, mqtt_pass)) {
            Serial.println("connected");
            for (const auto& topic : mqtt_topics) {
                client.subscribe(topic.c_str());
            }
            client.subscribe(mqtt_topic_checkserver);
        } else {
            Serial.print("failed, rc=");
            Serial.println(client.state());
            delay(2000);
        }
    }
}

void callback(char* topic, byte* payload, unsigned int length) {
    String message = "";
    for (int i = 0; i < length; i++) {
        message += (char)payload[i];
    }

    if (message.length() == 0) return;

    // ป้องกัน Message ซ้ำในเสี้ยววินาที
    static String last_message = "";
    if (message == last_message) {
        return;
    }
    last_message = message;

    Serial.print("Message received [");
    Serial.print(topic);
    Serial.print("]: ");
    Serial.println(message);

    String response = "";

    // --- ส่วนคำสั่ง Check Server ---
    if (strcmp(topic, mqtt_topic_checkserver) == 0) {
        String clientId = "Watsom"; 
        if (message == "-Netstart") {
            check_active = true;
            response = "Network start " + clientId;
        } else if (message == "-Stop") {
            check_active = false;
            response = "Network stopped from " + clientId;
        } else if (message == "-Check") {
            response = "Server Alive from " + clientId;
        }

        if (response.length() > 0) {
            client.publish(mqtt_topic_checkserver, response.c_str());
        }
    }
    // --- ส่วนคำสั่งควบคุม Relay และส่ง API ---
    else if (mqtt_topics.size() > 0 && strcmp(topic, mqtt_topics[0].c_str()) == 0) {
        
        if (message == "1") { 
          digitalWrite(relay_pin1, LOW);
          relay1_active = true;
          relay1_start_time = millis();
          response = "Relay 1 ON (MQTT) & API Sending...";
    // เปลี่ยน ActionName เป็น MQTTCommand
          sendApiNotification("{\"ActionName\":\"เปิดไม้กั้นผ่านระบบ LPR\", \"Channel\":\"ทางเข้า\", \"ViilageShortName\":\"Watsom\"}"); 
        } 
        else if (message == "01") {
            digitalWrite(relay_pin1, HIGH);
            relay1_active = false;
            response = "Relay 1 OFF Success";
        } 
        else if (message == "2") { 
            digitalWrite(relay_pin2, LOW);
            relay2_active = true;
            relay2_start_time = millis();
            response = "Relay 2 ON (MQTT) & API Sending...";
            // 📌 ส่ง API พร้อม Monitor
            sendApiNotification("{\"ActionName\":\"เปิดไม้กั้นผ่านระบบ LPR\", \"Channel\":\"ทางออก\", \"ViilageShortName\":\"Watsom\"}"); 
        } 
        else if (message == "02") {
            digitalWrite(relay_pin2, HIGH);
            relay2_active = false;
            response = "Relay 2 OFF Success";
        }

        if (response.length() > 0) {
            client.publish(mqtt_topic_checkserver, response.c_str());
        }
    }
}

void setup() {
    Serial.begin(115200);
    EEPROM.begin(EEPROM_SIZE); 
    loadSettingsFromEEPROM(); 

    pinMode(relay_pin1, OUTPUT);
    pinMode(relay_pin2, OUTPUT);
    
    // 📌 ตั้งค่าโหมดของขา Input ทั้ง 2 ตัว
    pinMode(input_pin1, INPUT_PULLUP); 
    pinMode(input_pin2, INPUT_PULLUP); 

    digitalWrite(relay_pin1, HIGH);
    digitalWrite(relay_pin2, HIGH);

    setup_wifi();

    server.on("/", HTTP_GET, handleRoot);
    server.on("/setup", HTTP_POST, handleSetup);
    server.on("/clear", HTTP_GET, []() {
      clearEEPROM();
      server.send(200, "text/html", "<h2>EEPROM Cleared</h2><p>The device will now restart.</p>");
      delay(1000);
      ESP.restart();
    });

    server.begin();
    client.setServer(mqtt_server, mqtt_port);
    client.setCallback(callback);
    espClient.setInsecure();
    reconnect();
}

void clearEEPROM() {
    for (int i = 0; i < EEPROM_SIZE; i++) {
        EEPROM.write(i, 0);
    }
    EEPROM.commit();
    storedSSID = "";
    storedPass = "";
    mqtt_topics.clear();
    Serial.println("EEPROM cleared!");
}

unsigned long wifi_disconnect_start = 0;
const unsigned long wifi_disconnect_timeout = 10 * 60 * 200;

void loop() {
    client.loop();
    server.handleClient();

    unsigned long now = millis();

    // --- ส่วนปิด Relay อัตโนมัติ ---
    if (relay1_active && now - relay1_start_time >= relay_duration) {
        digitalWrite(relay_pin1, HIGH);
        relay1_active = false;
        Serial.println("Relay 1: OFF (Auto)"); 
    }
    if (relay2_active && now - relay2_start_time >= relay_duration) {
        digitalWrite(relay_pin2, HIGH);
        relay2_active = false;
        Serial.println("Relay 2: OFF (Auto)");
    }

    // --- ส่วนเช็คการเชื่อมต่อ WiFi ---
    if (WiFi.status() != WL_CONNECTED) {
        if (wifi_disconnect_start == 0) {
            wifi_disconnect_start = now;
            Serial.println("WiFi disconnected, starting 2-minute timer...");
        } else if (now - wifi_disconnect_start >= wifi_disconnect_timeout) {
            Serial.println("WiFi disconnected for too long. Restarting...");
            delay(1000);   
            ESP.restart();
        }
    } else {
        wifi_disconnect_start = 0;
    }

    if (!client.connected()) {
        reconnect();
    }

    if (check_active && now - last_check_time >= check_interval) {
        last_check_time = now;
        client.publish(mqtt_topic_checkserver, ("Test Network " + String("WatSomanas")).c_str());
    }

    // 📌 --- ส่วนอ่านค่า Button 1 (IN) ---
    int reading1 = digitalRead(input_pin1);
    if (reading1 != last_input_state1) {
        last_debounce_time1 = now;
    }
    if ((now - last_debounce_time1) > debounce_delay) {
        static bool current_state1 = HIGH;
        if (reading1 != current_state1) {
            current_state1 = reading1;
            if (current_state1 == LOW) { 
                Serial.println("Button 1 detected! Sending Manual IN to API...");
                // เปลี่ยน ActionName เป็น ManualButton
                sendApiNotification("{\"ActionName\":\"เปิดไม้กั้นผ่านปุ่ม Manual\", \"Channel\":\"ทางเข้า\", \"ViilageShortName\":\"Watsom\"}"); 
            }
        }
    }
    last_input_state1 = reading1;

    // 📌 --- ส่วนอ่านค่า Button 2 (OUT) ---
    int reading2 = digitalRead(input_pin2);
    if (reading2 != last_input_state2) {
        last_debounce_time2 = now;
    }
    if ((now - last_debounce_time2) > debounce_delay) {
        static bool current_state2 = HIGH;
        if (reading2 != current_state2) {
            current_state2 = reading2;
            if (current_state2 == LOW) { 
                Serial.println("Button 2 detected! Sending Manual OUT to API...");
                // เปลี่ยน ActionName เป็น ManualButton
                sendApiNotification("{\"ActionName\":\"เปิดไม้กั้นผ่านปุ่ม Manual\", \"Channel\":\"ทางออก\", \"ViilageShortName\":\"Watsom\"}");  
            }
        }
    }
    last_input_state2 = reading2;
}
