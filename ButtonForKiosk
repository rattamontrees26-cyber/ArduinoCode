void setup() {
  // initialize serial:
  Serial.begin(9600);
  // reserve 200 bytes for the inputDoor:
  inputDoor.reserve(200);
  pinMode(PushButton2, INPUT_PULLUP);
  pinMode(PushButton3, INPUT_PULLUP);
  pinMode(PushButton4, INPUT_PULLUP);
  pinMode(PushButton5, INPUT_PULLUP);
  pinMode(PushButton6, INPUT_PULLUP);
  pinMode(PushButton7, INPUT_PULLUP);
  
  pinMode(OutputDevice8, OUTPUT);   
  pinMode(OutputDevice9, OUTPUT);   
  pinMode(OutputDevice10, OUTPUT);   
  pinMode(OutputDevice11, OUTPUT);   
  pinMode(OutputDevice12, OUTPUT); 
  pinMode(OutputDevice13, OUTPUT); 
  
  digitalWrite(OutputDevice8, HIGH); 
  digitalWrite(OutputDevice9, HIGH); 
  digitalWrite(OutputDevice10, HIGH); 
  digitalWrite(OutputDevice11, HIGH); 
  digitalWrite(OutputDevice12, HIGH); 
  digitalWrite(OutputDevice13, HIGH); 
}

void loop() {
  // print the string when a newline arrives:
  CheckReceivePushButton();
 //CheckReceiveAndHighOutPutDevice();
CheckReceiveAndLowOutPutDevice();
