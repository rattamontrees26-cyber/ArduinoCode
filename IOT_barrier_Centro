#include <WiFi.h>
#include <WebServer.h>
#include <PubSubClient.h>
#include <WiFiClientSecure.h>
#include <EEPROM.h>
#include <vector>

const int relay_pin1 = 22;
const int relay_pin2 = 23;

char mqtt_server[] = "192.168.1.200";
int mqtt_port = 8883;
char mqtt_user[] = "elid";
char mqtt_pass[] = "12345";
char mqtt_topic_checkserver[] = "checkserverklasssilom";

WiFiClientSecure espClient;
PubSubClient client(espClient);
WebServer server(80);

bool relay1_active = false;
bool relay2_active = false;
unsigned long relay1_start_time = 0;
unsigned long relay2_start_time = 0;
const unsigned long relay_duration = 500;

bool check_active = false;
unsigned long last_check_time = 0;
const unsigned long check_interval = 1000;

std::vector<String> mqtt_topics;
String storedSSID = "";
String storedPass = "";

#define EEPROM_SIZE 512

void setup_wifi() {
    WiFi.mode(WIFI_STA);
    WiFi.begin(storedSSID.c_str(), storedPass.c_str());

    Serial.println("Connecting to WiFi...");
    int retries = 0;
    while (WiFi.status() != WL_CONNECTED && retries < 30) {
        delay(1000);
        Serial.print(".");
        retries++;
        yield();
    }

    if (WiFi.status() == WL_CONNECTED) {
        Serial.println("\nWiFi Connected!");
        Serial.print("IP Address: ");
        Serial.println(WiFi.localIP());
    } else {
        Serial.println("\nFailed to connect to WiFi.");
        WiFi.mode(WIFI_AP);
        WiFi.softAPConfig(IPAddress(192,168,4,1), IPAddress(192,168,4,1), IPAddress(255,255,255,0));
        WiFi.softAP("IOT_klasssilomSetup", "");
        Serial.println("Started AP Mode at 192.168.4.1");
    }
}

String scanWiFiNetworks() {
    String wifiList = "<select name='ssid'>";
    int n = WiFi.scanNetworks();
    for (int i = 0; i < n; i++) {
        wifiList += "<option value='" + WiFi.SSID(i) + "'>" + WiFi.SSID(i) + "</option>";
    }
    wifiList += "</select>";
    return wifiList;
}

void saveSettingsToEEPROM(const String& ssid, const String& password, const String& mqtt_topic) {
    EEPROM.write(0, ssid.length());
    for (int i = 0; i < ssid.length(); i++) {
        EEPROM.write(1 + i, ssid[i]);
    }

    int password_offset = 1 + ssid.length();
    EEPROM.write(password_offset, password.length());
    for (int i = 0; i < password.length(); i++) {
        EEPROM.write(password_offset + 1 + i, password[i]);
    }

    int mqtt_topic_offset = password_offset + 1 + password.length();
    EEPROM.write(mqtt_topic_offset, mqtt_topic.length());
    for (int i = 0; i < mqtt_topic.length(); i++) {
        EEPROM.write(mqtt_topic_offset + 1 + i, mqtt_topic[i]);
    }

    EEPROM.commit();  
}

void loadSettingsFromEEPROM() {
    int ssid_length = EEPROM.read(0);
    char ssid[ssid_length + 1];
    for (int i = 0; i < ssid_length; i++) {
        ssid[i] = EEPROM.read(1 + i);
    }
    ssid[ssid_length] = '\0';

    int password_offset = 1 + ssid_length;
    int password_length = EEPROM.read(password_offset);
    char password[password_length + 1];
    for (int i = 0; i < password_length; i++) {
        password[i] = EEPROM.read(password_offset + 1 + i);
    }
    password[password_length] = '\0';

    int mqtt_topic_offset = password_offset + 1 + password_length;
    int mqtt_topic_length = EEPROM.read(mqtt_topic_offset);
    char mqtt_topic[mqtt_topic_length + 1];
    for (int i = 0; i < mqtt_topic_length; i++) {
        mqtt_topic[i] = EEPROM.read(mqtt_topic_offset + 1 + i);
    }
    mqtt_topic[mqtt_topic_length] = '\0';

    storedSSID = String(ssid);
    storedPass = String(password);
    mqtt_topics.push_back(String(mqtt_topic));

  
    Serial.println("Loaded settings from EEPROM:");
    Serial.println("SSID: " + storedSSID);
    Serial.println("Password: " + storedPass);
    Serial.println("MQTT Topic: " + String(mqtt_topic));
}
