#include <SPI.h>
#include <MFRC522.h>

#define SS_PIN   21     // SDA
#define RST_PIN  22

#define SCK_PIN  18
#define MISO_PIN 19
#define MOSI_PIN 23

MFRC522 mfrc522(SS_PIN, RST_PIN);
MFRC522::MIFARE_Key key;

void setup() {
  Serial.begin(9600);

  // เริ่ม SPI สำหรับ ESP32
  SPI.begin(SCK_PIN, MISO_PIN, MOSI_PIN, SS_PIN);

  mfrc522.PCD_Init();

  for (byte i = 0; i < 6; i++) {
    key.keyByte[i] = 0xFF;
  }

  Serial.println("พร้อมอ่านบัตร MIFARE Classic 1K (ESP32)...");
}

void loop() {

  if (!mfrc522.PICC_IsNewCardPresent()) return;
  if (!mfrc522.PICC_ReadCardSerial())   return;

  Serial.println("================================");
  Serial.print("UID: ");
  for (byte i = 0; i < mfrc522.uid.size; i++) {
    if (mfrc522.uid.uidByte[i] < 0x10) Serial.print("0");
    Serial.print(mfrc522.uid.uidByte[i], HEX);
    Serial.print(" ");
  }
  Serial.println("\n");

  byte buffer[18];
  byte size = sizeof(buffer);

  // MIFARE Classic 1K มี 16 sector
  for (byte sector = 7; sector < 8; sector++) {

    Serial.print("Sector ");
    Serial.println(sector);

    byte blockAddr = sector * 4;
                                       
    MFRC522::StatusCode status;
    status = mfrc522.PCD_Authenticate(
               MFRC522::PICC_CMD_MF_AUTH_KEY_A,
               blockAddr,
               &key,
               &(mfrc522.uid)
             );

    if (status != MFRC522::STATUS_OK) {
      Serial.print("  Auth ไม่ผ่าน: ");
      Serial.println(mfrc522.GetStatusCodeName(status));
      continue;
    }

    for (byte block = 0; block < 4; block++) {
      byte currentBlock = blockAddr + block;

      status = mfrc522.MIFARE_Read(currentBlock, buffer, &size);

      Serial.print("  Block ");
      Serial.print(currentBlock);
      Serial.print(": ");

      if (status == MFRC522::STATUS_OK) {
        for (byte i = 0; i < 16; i++) {
          if (buffer[i] < 0x10) Serial.print("0");
          Serial.print(buffer[i], HEX);
          Serial.print(" ");
        }
        Serial.println();
      } else {
        Serial.print("อ่านไม่ได้ (");
        Serial.print(mfrc522.GetStatusCodeName(status));
        Serial.println(")");
      }
    }
    Serial.println();
  }

  mfrc522.PICC_HaltA();
  mfrc522.PCD_StopCrypto1();
  delay(2000);
}
