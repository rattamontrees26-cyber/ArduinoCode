    String h = "<html><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1'>";
    h += "<style>body{font-family:sans-serif; background:#eef2f3; padding:20px;} .card{background:white; padding:20px; border-radius:10px; box-shadow:0 2px 5px rgba(0,0,0,0.1); max-width:400px; margin:auto;} ";
    h += "input{width:100%; padding:12px; margin:8px 0; border:1px solid #ddd; border-radius:5px; box-sizing:border-box;} ";
    h += ".btn-save{background:#4CAF50; color:white; border:none; padding:12px; width:100%; border-radius:5px; cursor:pointer; font-size:16px;} ";
    h += ".btn-restart{background:#2196F3; color:white; border:none; padding:12px; width:100%; border-radius:5px; cursor:pointer; font-size:16px; margin-top:10px;}</style></head><body>";
    
    h += "<div class='card'><h2>Slave 4-CH Setup</h2>";
    h += "<p>UID: <b>" + myUID + "</b><br>ID: <b>" + String(assignedID) + "</b><br>IP: <b>" + WiFi.localIP().toString() + "</b></p><hr>";
    
    h += "<form action='/s' method='POST'>";
    h += "WiFi SSID:<input name='s' value='"+storedSSID+"'>";
    h += "WiFi Pass:<input name='p' type='password' placeholder='Password'>";
    h += "Mother SN:<input name='sn' value='"+targetMotherSN+"' placeholder='HUB-XXXX'>";
    h += "<input type='submit' value='Save & Reboot' class='btn-save'></form>";

    h += "<form action='/restart' method='POST' onsubmit=\"return confirm('ยืนยันการ Restart?')\">";
    h += "<button type='submit' class='btn-restart'>Restart Slave Device</button></form></div></body></html>";
    
    server.send(200, "text/html", h);
}

void handleSave() {
    saveStringToEEPROM(SSID_ADDR, server.arg("s"));
    saveStringToEEPROM(PASS_ADDR, server.arg("p"));
    saveStringToEEPROM(SN_ADDR, server.arg("sn"));
    EEPROM.write(ID_ADDR, 0); EEPROM.commit();
    server.send(200, "text/html", "Saved! Rebooting...");
    delay(2000); ESP.restart();
}

void handleRestart() {
    server.send(200, "text/html", "Restarting...");
    delay(2000); ESP.restart();
}

// ------------------------- Setup & Loop -------------------------
void setup() {
    Serial.begin(115200);
    EEPROM.begin(EEPROM_SIZE);

    for (int i = 0; i < NUM_CHANNELS; i++) {
        pinMode(buttonPins[i], INPUT_PULLUP);
        pinMode(relayPins[i], OUTPUT);
        digitalWrite(relayPins[i], HIGH);
    }

    WiFi.mode(WIFI_STA);
    uint64_t chipid = ESP.getEfuseMac();
    char uidChar[13];
    sprintf(uidChar, "%04X%08X", (uint16_t)(chipid >> 32), (uint32_t)chipid);
    myUID = String(uidChar);

    storedSSID = loadStringFromEEPROM(SSID_ADDR);
    storedPass = loadStringFromEEPROM(PASS_ADDR);
    targetMotherSN = loadStringFromEEPROM(SN_ADDR);
    assignedID = EEPROM.read(ID_ADDR);

    if (storedSSID != "") {
        WiFi.begin(storedSSID.c_str(), storedPass.c_str());
        int r = 0; while (WiFi.status() != WL_CONNECTED && r < 20) { delay(1000); r++; Serial.print(".");}
    }

    if (WiFi.status() != WL_CONNECTED) {
        WiFi.mode(WIFI_AP);
        WiFi.softAP(("SLAVE_4CH_" + myUID.substring(myUID.length()-4)).c_str());
        Serial.println("\nAP Mode Started");
    }

    server.on("/", handleRoot);
    server.on("/s", handleSave);
    server.on("/restart", HTTP_POST, handleRestart);
    server.begin();

    espClient.setInsecure();
    client.setServer(mqtt_server, 8883);
    client.setCallback(callback);
}

void loop() {
    server.handleClient();
    if (WiFi.status() == WL_CONNECTED) {
        if (!client.connected()) reconnect();
        client.loop();

        if (assignedID == 0 || assignedID == 255) {
            static unsigned long lastDiscovery = 0;
            if (millis() - lastDiscovery > 10000) {
                lastDiscovery = millis();
                if (targetMotherSN != "") {
                    JsonDocument doc; doc["uid"] = myUID;
                    char buffer[128]; serializeJson(doc, buffer);
                    client.publish((targetMotherSN + "/discovery").c_str(), buffer);
                    client.subscribe(("discovery/reply/" + myUID).c_str());
                    Serial.println("Sent Discovery to Mother: " + targetMotherSN);
                }
            }
        }
    }
    checkButtons();
}

// --- ฟังก์ชัน Reconnect ที่ปรับปรุงใหม่ (เพิ่ม LWT Offline) ---
void reconnect() {
    while (!client.connected() && WiFi.status() == WL_CONNECTED) {
        
        // เตรียม Topic และข้อความ JSON สำหรับ Offline (LWT)
        String statusTopic = targetMotherSN + "/node" + String(assignedID) + "/status";
        String offlineJson = "{\"node_id\":" + String(assignedID) + ",\"uid\":\"" + myUID + "\",\"status\":\"Offline\",\"type\":\"system\"}";

        // เชื่อมต่อพร้อมฝาก "พินัยกรรม" ไว้ที่ Broker
        if (client.connect(myUID.c_str(), mqtt_user, mqtt_pass, statusTopic.c_str(), 1, true, offlineJson.c_str())) {
            Serial.println("Connected to HiveMQ");
            if (targetMotherSN != "") {
                client.subscribe((targetMotherSN + "/status").c_str());
                if (assignedID > 0 && assignedID != 255) {
                    client.subscribe((targetMotherSN + "/node" + String(assignedID) + "/cmd").c_str());
                    sendJsonStatus("system", "online"); 
                }
            }
        } else {
            Serial.print("Failed, rc="); Serial.print(client.state());
            delay(5000);
        }
    }
}
