#include <WiFi.h>
#include <WebServer.h>
#include <PubSubClient.h>
#include <WiFiClientSecure.h>
#include <EEPROM.h>
#include <ArduinoJson.h>

// --- ตั้งค่าขา Pin แบบ 4 ช่อง ---
#define NUM_CHANNELS 4
int buttonPins[NUM_CHANNELS] = {13, 14, 27, 33};
int relayPins[NUM_CHANNELS]  = {25, 26, 32, 22};

// --- ตัวแปรสำหรับ Debounce และสถานะ (Array) ---
int lastButtonStates[NUM_CHANNELS] = {HIGH, HIGH, HIGH, HIGH};
int stableButtonStates[NUM_CHANNELS] = {HIGH, HIGH, HIGH, HIGH};
unsigned long lastDebounceTimes[NUM_CHANNELS] = {0, 0, 0, 0};
int currentOutputStates[NUM_CHANNELS] = {HIGH, HIGH, HIGH, HIGH}; // HIGH = OFF (Active Low)

#define debounceDelay 50
#define EEPROM_SIZE 512
#define SSID_ADDR 0
#define PASS_ADDR 33
#define SN_ADDR 97
#define ID_ADDR 130

String myUID, storedSSID, storedPass, targetMotherSN;
int assignedID = 0;
bool isMotherOnline = false;

// --- MQTT Settings ---
char mqtt_server[] = "86d44431ea224155b65c9d6f1b9aa7ca.s1.eu.hivemq.cloud";
char mqtt_user[] = "Dzmorfin";
char mqtt_pass[] = "Radazrnakub13!";

WiFiClientSecure espClient;
PubSubClient client(espClient);
WebServer server(80);

// ------------------------- EEPROM Helpers -------------------------
void saveStringToEEPROM(int addr, String data) {
    EEPROM.write(addr, data.length());
    for (int i = 0; i < data.length(); i++) {
        EEPROM.write(addr + 1 + i, data[i]);
    }
    EEPROM.commit();
}

String loadStringFromEEPROM(int addr) {
    int len = EEPROM.read(addr);
    if (len > 100 || len < 0) return ""; 
    char data[len + 1];
    for (int i = 0; i < len; i++) {
        data[i] = (char)EEPROM.read(addr + 1 + i);
    }
    data[len] = '\0';
    return String(data);
}

// ------------------------- JSON Feedback -------------------------
void sendJsonStatus(String type, String status, int pin = -1, int state = -1) {
    if (assignedID > 0 && assignedID != 255) {
        JsonDocument doc;
        doc["node_id"] = assignedID;
        doc["uid"] = myUID;
        doc["ip"] = WiFi.localIP().toString();
        doc["type"] = type;
        doc["status"] = status;
        if (pin != -1) doc["pin"] = pin;
        if (state != -1) {
            doc["state"] = (state == 1) ? "ON" : "OFF";
        }

        char buffer[256];
        serializeJson(doc, buffer);
        String statusTopic = targetMotherSN + "/node" + String(assignedID) + "/status";
        client.publish(statusTopic.c_str(), buffer);
        Serial.println(">>> JSON Sent: " + String(buffer));
    }
}

// ------------------------- Check Buttons Logic -------------------------
void checkButtons() {
    for (int i = 0; i < NUM_CHANNELS; i++) {
        int reading = digitalRead(buttonPins[i]);
        if (reading != lastButtonStates[i]) {
            lastDebounceTimes[i] = millis();
        }

        if ((millis() - lastDebounceTimes[i]) > debounceDelay) {
            if (reading != stableButtonStates[i]) {
                stableButtonStates[i] = reading;
                if (stableButtonStates[i] == LOW) { // มีการกดปุ่มลงจริง
                    currentOutputStates[i] = !currentOutputStates[i];
                    digitalWrite(relayPins[i], currentOutputStates[i]);
                    
                    int reportVal = (currentOutputStates[i] == LOW) ? 1 : 0;
                    sendJsonStatus("manual_control", "success", relayPins[i], reportVal);
                    Serial.printf("Button %d (Pin %d) is %s\n", i+1, relayPins[i], (reportVal==1?"ON":"OFF"));
                }
            }
        }
        lastButtonStates[i] = reading;
    }
}

// ------------------------- MQTT Callback -------------------------
void callback(char* topic, byte* payload, unsigned int length) {
    String strTopic = String(topic);
    
    if (strTopic == targetMotherSN + "/status") {
        JsonDocument doc;
        if (!deserializeJson(doc, payload, length)) {
            String s = doc["status"] | "";
            isMotherOnline = (s == "Online");
        } else {
            String message = "";
            for (int i = 0; i < length; i++) message += (char)payload[i];
            isMotherOnline = (message == "Online");
        }
        return; 
    }

    if (strTopic == "discovery/reply/" + myUID) {
        JsonDocument doc;
        if (!deserializeJson(doc, payload, length)) {
            int newID = doc["id"];
            if (newID > 0) {
                assignedID = newID;
                EEPROM.write(ID_ADDR, assignedID);
                EEPROM.commit();
                sendJsonStatus("registration", "success");
                delay(1000); ESP.restart();
            }
        }
        return;
    }

    if (assignedID > 0 && assignedID != 255) {
        JsonDocument doc;
        DeserializationError error = deserializeJson(doc, payload, length);
        int pin = -1, state = -1;

        if (!error) {
            pin = doc["pin"];
            if (doc["state"].is<const char*>()) {
                String s = doc["state"].as<String>(); s.toUpperCase();
                state = (s == "ON") ? 1 : 0;
            } else { state = doc["state"] | 0; }
        } else {
            String message = "";
            for (int i = 0; i < length; i++) message += (char)payload[i];
            int colonPos = message.indexOf(':');
            if (colonPos > 0) {
                pin = message.substring(0, colonPos).toInt();
                state = message.substring(colonPos + 1).toInt();
            }
        }

        if (pin != -1) {
            for (int i = 0; i < NUM_CHANNELS; i++) {
                if (relayPins[i] == pin) {
                    currentOutputStates[i] = (state == 1) ? LOW : HIGH;
                    pinMode(pin, OUTPUT);
                    digitalWrite(pin, currentOutputStates[i]);
                    sendJsonStatus("remote_control", "success", pin, state);
                    break;
                }
            }
        }
    }
}

